APP_NAME=ai-backend-foundation
APP_VERSION=0.1.0
APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_USER=ai_backend_user
POSTGRES_PASSWORD=ai_backend_password
POSTGRES_DB=ai_backend_foundation
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ai_backend_user:ai_backend_password@postgres:5432/ai_backend_foundation

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0